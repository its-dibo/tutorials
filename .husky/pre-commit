# This prevents the error `pnpm not found` when committing changes 
# using the vscode interface directly
# it works when committing changes using the terminal (even the vscode's terminal) because it loads ~/.bashrc
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"

pnpm dlx lint-staged
