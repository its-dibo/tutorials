{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  // format the code with prettier then fix with eslint
  // todo: get full list of available actions from all plugins and vscode
  "editor.codeActionsOnSave": ["source.formatDocument", "source.fixAll.eslint"],
  "files.autoSave": "off",
  "editor.fastScrollSensitivity": 3,
  "editor.mouseWheelZoom": true,
  "editor.showFoldingControls": "always",
  "editor.stablePeek": true,
  "editor.fontSize": 16,
  "diffEditor.codeLens": true,
  "diffEditor.renderSideBySide": false,
  "window.title": "${dirty}${rootName} ${activeEditorShort}",
  "explorer.confirmDelete": false,
  "explorer.decorations.badges": false,
  "git.allowForcePush": true,
  "angular.enable-strict-mode-prompt": false,
  "js/ts.implicitProjectConfig.experimentalDecorators": true,
  "editor.minimap.enabled": false,
  "editor.dragAndDrop": true,
  "eslint.alwaysShowStatus": true,
  "eslint.format.enable": true,
  "eslint.lintTask.enable": true,
  // cli options for eslint. see package.scripts.lint:eslint
  // the cmd flags to be run when running a task for linting a whole folder
  // must be aligned with the flags of the script `lint:eslint` in package.scripts{}
  "eslint.lintTask.options": "--fix --config=eslint.config.ts",
  // languages that eslint will be activated for
  // todo: enable for all languages,
  // ignorePatterns option ignores files that eslint shouldn't be activated for
  "eslint.probe": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "vue",
    "markdown",
    "json",
    "css",
    "scss"
  ],
  "eslint.useESLintClass": true,
  // when scrolling down, the function diffenition will be sticked
  // so you know which function you are scrolling in
  "editor.stickyScroll.enabled": true,
  "editor.stickyScroll.maxLineCount": 5,
  "editor.suggest.matchOnWordStartOnly": true,
  // prompt to change the relative files paths when moving the md file to another location
  "markdown.experimental.updateLinksOnFileMove.enabled": "prompt",
  // Bring uncommitted changes with you when moving across development environments
  "workbench.experimental.editSessions.autoStore": "onShutdown",
  "workbench.experimental.editSessions.enabled": true,
  // maximum files to be opened
  "vscode-open-files-in-directory.maxFiles": 1000,
  // Maximum depth to traverse through subfolders
  "vscode-open-files-in-directory.maxRecursiveDepth": 50,
  "task.allowAutomaticTasks": "on",
  "npm.packageManager": "pnpm",
  "search.exclude": {
    "**/dist": true,
    "docs": true,
    ".nx": true,
    "pnpm-lock.yaml": true,
    "package-lock.json": true,
    "yarn.lock": true
  },
  "files.watcherExclude": {
    ".nx": true,
    "**/.angular": true,
    "**/dist": true,
    "**/node_modules": true,
    "docs": true
  },

  // automatically run `git commit` after the commit message is created
  // if `git.enableSmartCommit` enabled, it will automatically stage the modified files if there is no staged files
  "conventionalCommits.autoCommit": true,
  "conventionalCommits.gitmoji": false,
  "conventionalCommits.lineBreak": "\\n",
  // add the body in the source control tab directly
  "conventionalCommits.promptBody": false,
  "conventionalCommits.promptFooter": false,
  "conventionalCommits.": false,
  // when running `git commit` and no staged files, it will automatically stage the modified files
  "git.enableSmartCommit": true,
  "git.smartCommitChanges": "all",
  // if you want to automatically push or sync after creating the commit
  // i.e. run `git push` automatically after running `git commit`
  "git.postCommitCommand": "none",
  "nxConsole.generateAiAgentRules": true,
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json5]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-docker"
  },
  // enable Typescript native
  // https://devblogs.microsoft.com/typescript/typescript-native-port/
  // https://devblogs.microsoft.com/typescript/announcing-typescript-native-previews/
  "typescript.experimental.useTsgo": false
}
