
# help.github.com/ignore-files
# if you modified this file, also update .dockerignore

# .env is allowed to be committed, because the project runs in its own devContainer
# and shipped with its own database
# as a result .env now replaces .env.example
# also, .env.production can be committed, but the sensitive values must be encrypted using dotenvx
# or leaved empty to be set by the CI/CD secrets
# *.env
*.env.*
!*.env.example
!*.env.vault

# open code auth token
.opencode-key

# auto generated Swagger metadata
nest-swagger-metadata.js

node_modules
dist
out-tsc
/tmp
bazel-out
*.log
*.cache
*.tmp
.angular
// tarball files generated by `npm pack`
*.tgz
.nx/cache
.nx/workspace-data
.eslintcache

# React apps
.next
next-env.d.ts
.vercel

# see ./esbuild.config.ts
tsconfig.declarations.json

# Nest metadata for swagger (auto generated)
**/nest-swagger-metadata.ts

# any folder or file starts with `~`
# todo: replace all files ends with "~~" or "!!" such as "test!!/*" to be start with "~"
~*

# test coverage
coverage

# profiling files
chrome-profiler-events*.json
speed-measure-plugin*.json

# IDEs and editors
.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# test files
coverage

# misc
.sass-cache
connect.lock
coverage
typings
.history


# System Files
.DS_Store
Thumbs.db

# tsbuild info
*.tsbuildinfo

