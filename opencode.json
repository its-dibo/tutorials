{
  "$schema": "https://opencode.ai/config.json",
  "model": "zen/sonnet",
  "provider": {
    "opencode": {
      "options": {
        "apiKey": "{file:.opencode-key}"
      }
    }
  },
  "mcp": {
    "nx-mcp": {
      "type": "local",
      "command": ["npx", "nx", "mcp"],
      "enabled": true
    }
  }
}
